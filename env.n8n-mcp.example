# Copy these into ~/.openclaw/.env (or your shell profile) so Cursor inherits them.
# Never commit real tokens.

# Full MCP HTTP endpoint (must include /mcp-server/http)
N8N_MCP_URL=http://localhost:5678/mcp-server/http

# Personal MCP Access Token from n8n: Settings → Instance-level MCP → Connection details → Access Token
N8N_MCP_TOKEN=
