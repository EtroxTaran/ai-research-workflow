        "options": {}
      },
      "id": "set-params",
      "name": "Set Parameters & Generate run_id",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        250,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8001/sql",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "NS",
              "value": "research"
            },
            {
              "name": "DB",
              "value": "workflow"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/plain",
        "body": "=CREATE research_run SET query = '{{ $json.query }}', domain = '{{ $json.domain_hint }}', language = '{{ $json.language }}', status = 'pending', mode = '{{ $json.mode }}', trigger_source = '{{ $json.trigger_source }}', started_at = time::now(), n8n_execution_id = '{{ $execution.id }}', retry_count = 0;",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "surrealdb-create-run",
      "name": "SurrealDB \u2014 CREATE research_run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        500,
        100
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "surrealdb-basic-auth",
          "name": "SurrealDB Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const { execSync } = require(\"child_process\");\nconst query = $input.first().json.body?.query || $input.first().json.query || \"test\";\nconst safeQuery = query.replace(/\"/g, \"\").replace(/\\n/g, \" \").substring(0, 500);\nconst prompt = \"Analyze this research query and return ONLY a JSON object with: sub_questions (array with id, question, search_type), search_terms (object with primary_de, primary_en arrays), sources (array from: kb, web, miniflux), domain_classification (one of: tech, finance, academic, product_comparison, travel, general), mode (one of: quick, standard, deep). Rules: quick=simple facts, standard=comparisons, deep=high stakes. Query: \" + safeQuery;\ntry {\n  const result = execSync(\"gemini -p \\\"\" + prompt.replace(/\"/g, \"\") + \"\\\"\", {\n    encoding: \"utf-8\", timeout: 120000,\n    env: { ...process.env, PATH: \"/home/clawd/.local/bin:/home/clawd/.npm-global/bin:/usr/local/bin:/usr/bin:/bin:\" + (process.env.PATH || \"\"), HOME: \"/home/clawd\" },\n    cwd: \"/home/clawd\"\n  });\n  return [{ json: { stdout: result, query: query, exitCode: 0 } }];\n} catch (e) {\n  return [{ json: { stdout: e.stdout || \"\", stderr: e.stderr || e.message, query: query, exitCode: 1 } }];\n}",
        "mode": "runOnceForAllItems"
      },
      "id": "gemini-plan-inline",
      "name": "Gemini Query Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.stdout || \"\";\nconst query = $input.first().json.query || \"\";\nlet jsonStr = \"\";\nconst mdMatch = raw.match(/```json\\n?([\\s\\S]*?)\\n?```/);\nif (mdMatch) { jsonStr = mdMatch[1]; }\nelse {\n  const lines = raw.split(\"\\n\");\n  let bc = 0, js = -1, je = -1;\n  for (let i = 0; i < lines.length; i++) {\n    const l = lines[i];\n    if (l.startsWith(\"[ERROR]\") || l.startsWith(\"Loaded \") || l.startsWith(\"Server \") || !l.trim()) continue;\n    if (js === -1 && l.trim().startsWith(\"{\")) js = i;\n    if (js >= 0) { for (const c of l) { if (c===\"{\") bc++; if (c===\"}\") bc--; } if (bc===0) { je=i; break; } }\n  }\n  jsonStr = (js>=0 && je>=0) ? lines.slice(js,je+1).join(\"\\n\") : raw;\n}\nlet p;\ntry { p = JSON.parse(jsonStr.trim()); } catch(e) {\n  p = { sub_questions:[{id:\"sq-1\",question:query,search_type:\"web\"}], search_terms:{primary_de:[query],primary_en:[query]}, sources:[\"web\",\"kb\"], domain_classification:\"general\", mode:\"quick\" };\n}\nif (!p.scope) p.scope = {time_range:\"last_year\",languages:[\"de\",\"en\"]};\nif (!p.sources) p.sources = [\"web\",\"kb\"];\nconst vm = [\"quick\",\"standard\",\"deep\"];\nif (!vm.includes(p.mode)) p.mode = \"standard\";\nif (query.match(/\\[deep\\]/i)) p.mode = \"deep\";\nif (query.match(/\\[quick\\]/i)) p.mode = \"quick\";\nreturn [{json:{search_plan:p, mode:p.mode, query:query, language:$input.first().json.body?.language||\"de\"}}];",
        "mode": "runOnceForAllItems"
      },
      "id": "parse-plan-inline",
      "name": "Parse Search Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8001/sql",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "NS",
              "value": "research"
            },
            {
              "name": "DB",
              "value": "workflow"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
