        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/plain",
        "body": "=UPDATE research_run SET status = 'phase1', search_plan = {{ JSON.stringify($json.search_plan ?? {}) }}, mode = '{{ $('Set Parameters & Generate run_id').item.json.mode }}' WHERE n8n_execution_id = '{{ $execution.id }}';",
        "options": {}
      },
